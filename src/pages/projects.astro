---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const pageTitle = "Projects";
const pageDescription =
  "Selected work in applied ML, agents, diffusion, and signal processing.";

type Project = {
  title: string;
  meta: string;
  status?: "Live" | "In progress" | "Research";
  hook: string;
  description: string;
  stack: string[];
  links: { label: string; url: string }[];
};

const projects: Project[] = [
  {
    title: "3D-Agent",
    meta: "Graduation project · Team of 4",
    status: "In progress",
    hook: "Text in, 3D out — but smart about which model to use.",
    description:
      "A graduation project building the agent layer over a fragmented 3D generation ecosystem. The runtime decides between TRELLIS.2, PartCrafter, and Hunyuan3D for each request, then routes through a FastAPI + Modal inference backend with a Django web UI. I own the agent runtime and its 12-tool surface, plus an image-restyling preprocessor that conforms 2D inputs to an Objaverse-style distribution so reconstruction quality holds up across input styles.",
    stack: [
      "PyTorch",
      "LangChain",
      "FastAPI",
      "Modal",
      "Django",
      "Google AI Studio",
    ],
    links: [{ label: "GitHub", url: "https://github.com/hecrw/3D-Agent" }],
  },
  {
    title: "Diffusion Models for EEG Reconstruction",
    meta: "Research intern · University of Tsukuba",
    status: "Research",
    hook: "Diffusion models — the tech behind Stable Diffusion — applied to brain signals.",
    description:
      "A six-month research stint applying generative diffusion to high-density EEG. Implemented DDPM, DDIM, and LDM variants in PyTorch on the anphy-sleep dataset (29 subjects, 83-channel HD-EEG), then ran a controlled comparison of data-, noise-, and velocity-prediction objectives and landed on velocity-prediction. Proposed signal-space diffusion over the lab's default latent-space approach; the architecture was adopted after review for its better fit with EEG noise distributions.",
    stack: ["PyTorch", "DDPM", "DDIM", "LDM", "HD-EEG"],
    links: [
      { label: "University of Tsukuba", url: "https://www.tsukuba.ac.jp/" },
    ],
  },
  {
    title: "Falcon-RW 1B — 4-bit Quantization",
    meta: "Solo · 2025",
    status: "Live",
    hook: "A 1B-parameter LLM that runs on a laptop.",
    description:
      "Took Falcon-RW 1B from a float32 model that needs a real GPU down to NF4 4-bit with double quantization via bitsandbytes — roughly 75% smaller — without losing the ability to ship it as a real product. A bfloat16 compute dtype with a CUDA → MPS → CPU fallback chain and cached loading lets the same model power both a Gradio UI and a FastAPI /generate endpoint. Containerized with Docker, deployed to Hugging Face Spaces.",
    stack: [
      "Transformers",
      "bitsandbytes",
      "FastAPI",
      "Gradio",
      "Docker",
    ],
    links: [
      {
        label: "GitHub",
        url: "https://github.com/HamedDaoud/quantized-falcon-rw-1b",
      },
      {
        label: "Live demo",
        url: "https://huggingface.co/spaces/hameddaoud/quantized-falcon-rw-1b",
      },
    ],
  },
  {
    title: "FraudShieldML",
    meta: "Solo · 2025",
    status: "Live",
    hook: "Catching credit-card fraud where the positive class is 0.17% of the data.",
    description:
      "End-to-end fraud detection on a brutally imbalanced dataset, ending at 0.93 precision, 0.82 recall, and 0.86 PR AUC. The feature pipeline log-transforms amounts, cyclically encodes time-of-day, scales, and applies SMOTE to fight the class imbalance. A threshold-tuned Random Forest ships behind a FastAPI service and a Gradio UI, containerized with Docker Compose and deployed to Hugging Face Spaces.",
    stack: [
      "scikit-learn",
      "XGBoost",
      "SMOTE",
      "FastAPI",
      "Gradio",
      "Docker Compose",
    ],
    links: [
      {
        label: "GitHub",
        url: "https://github.com/HamedDaoud/FraudShieldML",
      },
      {
        label: "Live demo",
        url: "https://huggingface.co/spaces/hameddaoud/fraudshield-ml",
      },
    ],
  },
];

const statusStyles: Record<NonNullable<Project["status"]>, string> = {
  Live: "border-accent/40 text-accent",
  "In progress": "border-border opacity-80",
  Research: "border-border opacity-80",
};
---

<Layout
  title={`${pageTitle} | ${config.site.title}`}
  description={pageDescription}
>
  <Header />
  <Breadcrumb />
  <Main pageTitle={pageTitle} pageDesc={pageDescription}>
    <div class="mt-4 grid gap-6">
      {
        projects.map(project => (
          <article class="border-border hover:border-accent/50 group rounded-lg border p-5 transition-colors sm:p-6">
            <header class="mb-3 flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                <h2 class="text-xl font-semibold tracking-tight sm:text-2xl">
                  {project.title}
                </h2>
                {project.status && (
                  <span
                    class:list={[
                      "rounded-full border px-2 py-0.5 text-xs font-medium",
                      statusStyles[project.status],
                    ]}
                  >
                    {project.status}
                  </span>
                )}
              </div>
              <p class="text-sm opacity-70">{project.meta}</p>
            </header>

            <p class="text-accent mb-3 text-base italic sm:text-lg">
              {project.hook}
            </p>

            <p class="mb-4 leading-relaxed opacity-90">{project.description}</p>

            <ul class="mb-4 flex flex-wrap gap-1.5">
              {project.stack.map(item => (
                <li class="border-border bg-muted/30 rounded border px-2 py-0.5 font-mono text-xs">
                  {item}
                </li>
              ))}
            </ul>

            {project.links.length > 0 && (
              <div class="flex flex-wrap gap-2">
                {project.links.map(link => (
                  <a
                    href={link.url}
                    target={link.url.startsWith("http") ? "_blank" : undefined}
                    rel={link.url.startsWith("http") ? "noopener" : undefined}
                    class="border-border hover:border-accent hover:text-accent inline-flex items-center gap-1 rounded-md border px-2.5 py-1 text-sm font-medium transition-colors"
                  >
                    {link.label}
                    <span aria-hidden="true" class="text-xs">
                      &#8599;
                    </span>
                  </a>
                ))}
              </div>
            )}
          </article>
        ))
      }
    </div>
  </Main>
  <Footer />
</Layout>
